#!/usr/bin/env bash
set -euo pipefail
# Enhanced Nix update with progress tracking

# Run as your normal user, NOT with sudo: the flake update and build must run as
# the repo owner (nixswitch elevates only the activation step on its own).
if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    echo "❌ Don't run nixup with sudo — run it as your user." >&2
    echo "   It elevates only the activation step on its own." >&2
    exit 1
fi

echo "❄️  Nix Update & Rebuild"
echo "======================="
echo ""

# Navigate to dotfiles
pushd ~/.dotfiles > /dev/null

# Show current state
echo "📍 Current state:"
if [[ -f flake.lock ]]; then
    last_update=$(date -r flake.lock "+%Y-%m-%d %H:%M" 2>/dev/null || echo "unknown")
    echo "   Last update: $last_update"
fi
echo ""

# Update flake inputs
echo "🔄 [1/3] Updating flake inputs..."
echo "─────────────────────────────────"

if nix flake update 2>&1 | while IFS= read -r line; do
    if [[ "$line" =~ Updated.*input ]]; then
        input=$(echo "$line" | sed -E "s/.*'([^']+)'.*/\1/")
        echo "   ✓ Updated: $input"
    elif [[ "$line" =~ warning ]]; then
        echo "   ⚠ $line"
    fi
done; then
    echo ""
    echo "✅ Flake inputs updated"
else
    echo "❌ Failed to update flake inputs"
    popd > /dev/null
    exit 1
fi
echo ""

# Show what changed
echo "📝 Changes in flake.lock:"
if git diff --quiet -- flake.lock 2>/dev/null; then
    echo "   (no changes)"
else
    git diff --color=always --stat -- flake.lock 2>/dev/null | sed 's/^/   /'
fi
echo ""

# Build and switch
echo "🔨 [2/3] Building new configuration..."
echo "─────────────────────────────────────"
~/Scripts/nixswitch

if [[ $? -eq 0 ]]; then
    echo ""
    echo "🎉 [3/3] Update complete!"
    echo "─────────────────────────"

    # Show new state
    if [[ "$OSTYPE" == "darwin"* ]]; then
        new_gen=$(darwin-rebuild --list-generations 2>/dev/null | tail -1)
    else
        new_gen=$(nixos-rebuild list-generations 2>/dev/null | tail -1)
    fi

    echo "   New generation: $new_gen"
    echo ""
    echo "✨ Your system is now up to date!"
else
    echo ""
    echo "❌ Build failed. Check errors above."
    popd > /dev/null
    exit 1
fi

popd > /dev/null
